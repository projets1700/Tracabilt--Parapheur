{
  "expo": {
    "name": "TraçaParapheur",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logo_Parapheur.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/Logo_Parapheur.png",
      "resizeMode": "contain",
      "backgroundColor": "#009DBF"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.adam_91.mobile",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/Logo_Parapheur.png",
        "backgroundColor": "#009DBF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/Logo_Parapheur.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Nécessaire pour scanner les codes des parapheurs."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Nécessaire pour enregistrer la position GPS lors du scan."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "93a03948-cd4e-4bda-b9bc-c99d10164a92"
      }
    }
  }
}